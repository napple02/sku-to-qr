<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>東洋館出版社 - 書籍QRコード生成ツール</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <style>
        body {
            font-family: 'Helvetica Neue', Arial, 'Hiragino Kaku Gothic ProN', 'Hiragino Sans', Meiryo, sans-serif;
            background-color: #f9f9f9;
            color: #333;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }
        .container {
            background-color: #fff;
            padding: 30px;
            border-radius: 8px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            width: 100%;
            max-width: 400px;
            text-align: center;
        }
        h2 {
            margin-top: 0;
            font-size: 1.2rem;
            color: #444;
        }
        input[type="text"] {
            width: calc(100% - 22px);
            padding: 10px;
            margin: 10px 0;
            border: 1px solid #ccc;
            border-radius: 4px;
            font-size: 1rem;
            text-align: center;
        }
        button {
            width: 100%;
            padding: 12px;
            background-color: #0056b3;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 1rem;
            cursor: pointer;
            transition: background-color 0.2s;
        }
        button:hover {
            background-color: #004494;
        }
        .error-msg {
            color: #d9534f;
            font-size: 0.85rem;
            margin-bottom: 10px;
            height: 1em;
        }
        #qrcode {
            margin-top: 20px;
            display: flex;
            justify-content: center;
            min-height: 150px;
        }
        .url-display {
            margin-top: 15px;
            font-size: 0.85rem;
            color: #666;
            word-break: break-all;
        }
    </style>
</head>
<body>

    <div class="container">
        <h2>書籍QRコード生成ツール</h2>
        
        <p style="font-size: 0.9rem; color: #555;">4桁のSKUを入力してください</p>
        
        <input type="text" id="skuInput" placeholder="例: 1234" maxlength="4">
        
        <div id="errorMsg" class="error-msg"></div>
        
        <button onclick="generateQRCode()">QRコードを作成</button>

        <div id="qrcode"></div>
        <div id="urlDisplay" class="url-display"></div>
    </div>

    <script>
        function generateQRCode() {
            const sku = document.getElementById("skuInput").value;
            const errorMsg = document.getElementById("errorMsg");
            const qrcodeContainer = document.getElementById("qrcode");
            const urlDisplay = document.getElementById("urlDisplay");

            // 初期化
            errorMsg.textContent = "";
            urlDisplay.textContent = "";
            qrcodeContainer.innerHTML = ""; // 以前のQRコードを消去

            // バリデーション：4桁の半角数字かチェック
            if (!/^\d{4}$/.test(sku)) {
                errorMsg.textContent = "※4桁の半角数字を正しく入力してください。";
                return;
            }

            // URLの組み立て
            const targetUrl = "https://www.toyokan.co.jp/products/" + sku;

            // QRコードの生成
            new QRCode(qrcodeContainer, {
                text: targetUrl,
                width: 150,
                height: 150,
                colorDark : "#000000",
                colorLight : "#ffffff",
                correctLevel : QRCode.CorrectLevel.H // 誤り訂正レベル高（少し汚れがあっても読み取れる）
            });

            // 確認用URLテキストの表示
            urlDisplay.innerHTML = `リンク先: <br><a href="${targetUrl}" target="_blank">${targetUrl}</a>`;
        }
    </script>
</body>
</html>
